# Copy to .env and fill in ONE provider's key. The default provider is OpenAI,
# so setting OPENAI_API_KEY alone is enough to run.
#
#   cp .env.example .env
#
# .env is gitignored — never commit real keys.

# ── Default: OpenAI (works out of the box) ────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Pick a provider (default: openai) ─────────────────────────────────────────
# LLMSTXT_PROVIDER=openai        # openai | anthropic | deepseek | together | openrouter | groq | ollama
# LLMSTXT_MODEL=gpt-4o-mini      # override the provider's default model
# LLMSTXT_BASE_URL=              # override for any OpenAI-compatible endpoint
# LLMSTXT_API_KEY=               # generic key override (else the per-provider var below is used)

# ── Per-provider API keys (only the one you use is needed) ────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# TOGETHER_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# GROQ_API_KEY=gsk_...
# Ollama needs no key (LLMSTXT_PROVIDER=ollama, runs against http://localhost:11434/v1)
